rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Single authenticated user — all data readable/writable when signed in
    match /homework_types/{document=**} {
      allow read, write: if request.auth != null;
    }
    
    match /students/{document=**} {
      allow read, write: if request.auth != null;
    }
    
    match /homeworks/{document=**} {
      allow read, write: if request.auth != null;
    }
    
    match /chat_history/{document=**} {
      allow read, write: if request.auth != null;
    }
    
    // Config collection (API keys) - read only for authenticated users
    match /config/{document=**} {
      allow read: if request.auth != null;
      allow write: if false;
    }
    
    // Public access for contact form submissions
    match /contact_form/{document=**} {
      allow read: if request.auth != null;
      allow create: if request.resource.data.name != null 
        && request.resource.data.email != null;
    }
    
    // Default deny all
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
